{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/api/admin.php"
    },
    {
      "source": "/contact",
      "destination": "/api/contact.php"
    },
    {
      "source": "/leads",
      "destination": "/api/baba-leads.php"
    },
    {
      "source": "/index.php",
      "destination": "/api/index.php"
    },
    {
      "source": "/2-bhk-flat-in-bhiwandi",
      "destination": "/2-bhk-flat-in-bhiwandi.html"
    },
    {
      "source": "/2-bhk-flat-in-bhiwandi-price",
      "destination": "/2-bhk-flat-in-bhiwandi-price.html"
    },
    {
      "source": "/2-bhk-flat-in-bhiwandi-for-sale",
      "destination": "/2-bhk-flat-in-bhiwandi-for-sale.html"
    },
    {
      "source": "/2-bhk-flat-in-anjur-phata-bhiwandi",
      "destination": "/2-bhk-flat-in-anjur-phata-bhiwandi.html"
    },
    {
      "source": "/ready-to-move-flats-in-bhiwandi",
      "destination": "/ready-to-move-flats-in-bhiwandi.html"
    },
    {
      "source": "/bhiwandi-1-bhk-flat",
      "destination": "/bhiwandi-1-bhk-flat.html"
    },
    {
      "source": "/1-bhk-flat-in-bhiwandi-for-sale",
      "destination": "/1-bhk-flat-in-bhiwandi-for-sale.html"
    },
    {
      "source": "/bhiwandi-1-bhk-flat-price",
      "destination": "/bhiwandi-1-bhk-flat-price.html"
    },
    {
      "source": "/flats-in-bhiwandi",
      "destination": "/flats-in-bhiwandi.html"
    },
    {
      "source": "/flats-for-sale-in-bhiwandi-millat-nagar",
      "destination": "/flats-for-sale-in-bhiwandi-millat-nagar.html"
    },
    {
      "source": "/bhiwandi-flat-rate",
      "destination": "/bhiwandi-flat-rate.html"
    },
    {
      "source": "/((?!api|images|blog|.*\\.html$|.*\\.css$|.*\\.js$|.*\\.webp$|.*\\.png$|.*\\.jpg$|.*\\.ico$|robots\\.txt|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}




